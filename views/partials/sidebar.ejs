<aside class="dashboard-sidebar <%= user && user.userType === 'admin' ? 'admin-theme' : '' %>">
    <div class="sidebar-header">
        <i class="fas fa-user-circle user-avatar"></i>
        <div class="user-info">
            <% if (user) { %>
                <h3>Welcome Back</h3>
                <p>
                    <%= user.fullname %>
                </p>
                <span class="user-badge">
                    <%= user.userType.charAt(0).toUpperCase() + user.userType.slice(1) %>
                </span>
                <% } else { %>
                    <h3>Welcome</h3>
                    <p>Guest</p>
                    <% } %>
        </div>
    </div>

    <nav class="sidebar-nav">
        <!-- Common Links -->
        <a href="/dashboard" class="nav-item <%= typeof page !== 'undefined' && page === 'overview' ? 'active' : '' %>">
            <i class="fas fa-chart-line"></i>
            <span>Overview</span>
        </a>
        <a href="/dashboard/messages"
            class="nav-item <%= typeof page !== 'undefined' && page === 'messages' ? 'active' : '' %>">
            <i class="fas fa-envelope"></i>
            <span>Messages</span>
        </a>

        <!-- Buyer Links -->
        <% if (user && user.userType==='buyer' ) { %>
            <a href="/market" class="nav-item <%= typeof page !== 'undefined' && page === 'market' ? 'active' : '' %>">
                <i class="fas fa-store"></i>
                <span>Marketplace</span>
            </a>
            <a href="/dashboard/orders"
                class="nav-item <%= typeof page !== 'undefined' && page === 'orders' ? 'active' : '' %>">
                <i class="fas fa-shopping-bag"></i>
                <span>My Orders</span>
            </a>
            <% } %>

                <!-- Seller Links (Farmer/Supplier/Admin) -->
                <% if (user && (['farmer', 'supplier' , 'admin' ].includes(user.userType))) { %>
                    <a href="/market"
                        class="nav-item <%= typeof page !== 'undefined' && page === 'market' ? 'active' : '' %>">
                        <i class="fas fa-store"></i>
                        <span>Marketplace</span>
                    </a>
                    <a href="/market/add/new"
                        class="nav-item <%= typeof page !== 'undefined' && page === 'add-product' ? 'active' : '' %>">
                        <i class="fas fa-plus-circle"></i>
                        <span>Add Product</span>
                    </a>
                    <a href="/dashboard/sales"
                        class="nav-item <%= typeof page !== 'undefined' && page === 'sales' ? 'active' : '' %>">
                        <i class="fas fa-dollar-sign"></i>
                        <span>Sales & Orders</span>
                    </a>
                    <% } %>

                        <!-- Admin Only Links -->
                        <% if (user && user.userType==='admin' ) { %>
                            <a href="/dashboard/users"
                                class="nav-item <%= typeof page !== 'undefined' && page === 'users' ? 'active' : '' %>">
                                <i class="fas fa-users-cog"></i>
                                <span>Manage Users</span>
                            </a>
                            <% } %>

                                <!-- Common Footer Links -->
                                <a href="/dashboard/settings"
                                    class="nav-item <%= typeof page !== 'undefined' && page === 'settings' ? 'active' : '' %>">
                                    <i class="fas fa-cog"></i>
                                    <span>Settings</span>
                                </a>
                                <a href="/auth/logout" class="nav-item">
                                    <i class="fas fa-sign-out-alt"></i>
                                    <span>Logout</span>
                                </a>
    </nav>
</aside>