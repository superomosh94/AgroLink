<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/market.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body>
    <%- include('../partials/header') %>

        <main>
            <section class="market-hero">
                <div class="container">
                    <h1 class="page-title">Marketplace</h1>
                    <p class="page-subtitle">Discover quality agricultural products from verified sellers</p>
                </div>
            </section>

            <section class="market-content">
                <div class="container">
                    <form method="GET" action="/market" class="market-filters">
                        <div class="search-box">
                            <i class="fas fa-search"></i>
                            <input type="text" name="search" placeholder="Search products..." class="search-input"
                                value="<%= filters.search || '' %>">
                        </div>

                        <div class="filter-group">
                            <select name="category" class="filter-select" onchange="this.form.submit()">
                                <option value="">All Categories</option>
                                <option value="seeds" <%=filters.category==='seeds' ? 'selected' : '' %>>Seeds</option>
                                <option value="fertilizers" <%=filters.category==='fertilizers' ? 'selected' : '' %>
                                    >Fertilizers</option>
                                <option value="equipment" <%=filters.category==='equipment' ? 'selected' : '' %>
                                    >Equipment</option>
                                <option value="produce" <%=filters.category==='produce' ? 'selected' : '' %>>Fresh
                                    Produce</option>
                                <option value="livestock" <%=filters.category==='livestock' ? 'selected' : '' %>
                                    >Livestock</option>
                            </select>

                            <select name="sort" class="filter-select" onchange="this.form.submit()">
                                <option value="">Sort By: Latest</option>
                                <option value="price-low" <%=filters.sort==='price-low' ? 'selected' : '' %>>Price: Low
                                    to High</option>
                                <option value="price-high" <%=filters.sort==='price-high' ? 'selected' : '' %>>Price:
                                    High to Low</option>
                            </select>
                        </div>
                    </form>

                    <% if (products.length===0) { %>
                        <div class="no-products">
                            <i class="fas fa-box-open"
                                style="font-size: 80px; color: var(--gray-400); margin-bottom: var(--spacing-lg);"></i>
                            <h3>No Products Found</h3>
                            <p>Try adjusting your filters or search terms</p>
                        </div>
                        <% } else { %>
                            <div class="products-grid">
                                <% products.forEach(product=> {
                                    const categoryIcons = {
                                    'fertilizers': 'flask',
                                    'seeds': 'seedling',
                                    'equipment': 'cogs',
                                    'produce': 'apple-alt',
                                    'livestock': 'horse',
                                    'other': 'box'
                                    };
                                    %>
                                    <div class="product-card">
                                        <div class="product-image-wrapper">
                                            <% if (product.image_url) { %>
                                                <img src="<%= product.image_url %>" alt="<%= product.name %>"
                                                    class="product-image">
                                                <% } else { %>
                                                    <div class="product-image-placeholder">
                                                        <i
                                                            class="fas fa-<%= categoryIcons[product.category] || 'box' %>"></i>
                                                    </div>
                                                    <% } %>
                                                        <span class="product-badge">
                                                            <%= product.category.charAt(0).toUpperCase() +
                                                                product.category.slice(1) %>
                                                        </span>
                                                        <% if (product.is_organic) { %>
                                                            <span class="organic-badge"><i class="fas fa-leaf"></i>
                                                                Organic</span>
                                                            <% } %>
                                        </div>

                                        <div class="product-info">
                                            <h3 class="product-name">
                                                <%= product.name %>
                                            </h3>
                                            <div class="product-seller">
                                                <i class="fas fa-store"></i>
                                                <span>
                                                    <%= product.seller_name %>
                                                </span>
                                            </div>

                                            <div class="product-meta">
                                                <span class="meta-item">
                                                    <i class="fas fa-map-marker-alt"></i>
                                                    <%= product.location %>
                                                </span>
                                                <span class="meta-item">
                                                    <i class="fas fa-box"></i>
                                                    <%= product.stock_quantity %>
                                                        <%= product.unit %>
                                                </span>
                                            </div>

                                            <div class="product-footer">
                                                <span class="product-price">Ksh <%= parseFloat(product.price).toFixed(2)
                                                        %>
                                                </span>
                                                <a href="/market/<%= product.id %>" class="btn btn-primary btn-sm">
                                                    View Details
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                    <% }); %>
                            </div>
                            <% } %>
                </div>
            </section>

            <!-- Product Quick View Modal -->
            <div id="productModal" class="modal-overlay">
                <div class="modal-content">
                    <button class="close-modal" onclick="closeModal()">&times;</button>
                    <div class="modal-body">
                        <div class="modal-image-col">
                            <img id="modalImage" src="" alt="Product" class="modal-image">
                            <!-- Fallback icon container could go here if needed -->
                        </div>
                        <div class="modal-info-col">
                            <div class="modal-header">
                                <span id="modalCategory" class="modal-category"></span>
                                <h2 id="modalTitle" class="modal-title"></h2>
                                <div class="modal-seller">
                                    <i class="fas fa-store"></i> <span id="modalSeller"></span>
                                </div>
                            </div>

                            <div class="modal-price-section">
                                <span id="modalPrice" class="modal-price"></span>
                                <span id="modalStock" class="modal-stock-badge"></span>
                            </div>

                            <p id="modalDescription" class="modal-description"></p>

                            <div class="modal-meta-grid">
                                <div class="modal-meta-item">
                                    <i class="fas fa-map-marker-alt"></i> <span id="modalLocation"></span>
                                </div>
                                <div class="modal-meta-item">
                                    <i class="fas fa-box"></i> <span id="modalUnit"></span>
                                </div>
                            </div>

                            <div class="modal-actions">
                                <a id="modalViewLink" href="#" class="btn btn-primary btn-block">View Full Details</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>

        <script>
            // Store products in a global object for easy access
            const productsMap = {};
            
            <% products.forEach(function (p) { %>
                productsMap[<%= p.id %>] = {
                    id: <%= p.id %>,
                        name: "<%= p.name %>", // EJS automatically escapes by default? No, careful. 
                            // Let's use JSON.stringify for safety
                            name: <% - JSON.stringify(p.name) %>,
                                price: <%= p.price %>,
                                    image: <% - JSON.stringify(p.image_url) %>,
                                        category: <% - JSON.stringify(p.category) %>,
                                            seller: <% - JSON.stringify(p.seller_name) %>,
                                                stock: <%= p.stock_quantity %>,
                                                    unit: <% - JSON.stringify(p.unit) %>,
                                                        location: <% - JSON.stringify(p.location) %>,
                                                            description: <% - JSON.stringify(p.description) %>
                };
            <% }); %>

                function openProductModal(id) {
                    const data = productsMap[id];
                    if (!data) return;

                    const modal = document.getElementById('productModal');

                    // Populate data
                    document.getElementById('modalImage').src = data.image || '/images/default-product.png';
                    document.getElementById('modalCategory').textContent = data.category;
                    document.getElementById('modalTitle').textContent = data.name;
                    document.getElementById('modalSeller').textContent = data.seller;
                    document.getElementById('modalPrice').textContent = `Ksh ${parseFloat(data.price).toFixed(2)}`;
                    document.getElementById('modalDescription').textContent = data.description.substring(0, 150) + (data.description.length > 150 ? '...' : '');
                    document.getElementById('modalLocation').textContent = data.location;
                    document.getElementById('modalUnit').textContent = `${data.stock} ${data.unit} available`;

                    // Stock Badge
                    const stockEl = document.getElementById('modalStock');
                    if (data.stock > 0) {
                        stockEl.textContent = 'In Stock';
                        stockEl.className = 'modal-stock-badge success';
                    } else {
                        stockEl.textContent = 'Out of Stock';
                        stockEl.className = 'modal-stock-badge error';
                    }

                    // Link
                    const viewLink = document.getElementById('modalViewLink');
                    if (viewLink) viewLink.href = `/market/${data.id}`;

                    // Show modal
                    modal.classList.add('active');
                    document.body.style.overflow = 'hidden';
                }

            function closeModal() {
                const modal = document.getElementById('productModal');
                modal.classList.remove('active');
                document.body.style.overflow = '';
            }

            // Close on outside click
            window.onclick = function (event) {
                const modal = document.getElementById('productModal');
                if (event.target === modal) {
                    closeModal();
                }
            }
        </script>

        <%- include('../partials/footer') %>

            <script src="/js/main.js"></script>
</body>

</html>