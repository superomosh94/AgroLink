<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/product.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body>
    <%- include('../partials/header') %>

        <main>
            <div class="container">
                <nav class="breadcrumb">
                    <a href="/">Home</a>
                    <i class="fas fa-chevron-right"></i>
                    <a href="/market">Marketplace</a>
                    <i class="fas fa-chevron-right"></i>
                    <span>
                        <%= product.name %>
                    </span>
                </nav>

                <div class="product-detail">
                    <div class="product-gallery">
                        <div class="main-image">
                            <% if (product.image_url) { %>
                                <img src="<%= product.image_url %>" alt="<%= product.name %>"
                                    style="width: 100%; height: 100%; object-fit: cover; border-radius: var(--radius-lg);">
                                <% } else { const categoryIcons={ 'fertilizers' : 'flask' , 'seeds' : 'seedling'
                                    , 'equipment' : 'cogs' , 'produce' : 'apple-alt' , 'livestock' : 'horse' , 'other'
                                    : 'box' }; %>
                                    <i
                                        class="fas fa-<%= categoryIcons[product.category] || 'box' %> product-icon-large"></i>
                                    <% } %>
                        </div>
                    </div>

                    <div class="product-details">
                        <span class="product-category-badge">
                            <%= product.category.charAt(0).toUpperCase() + product.category.slice(1) %>
                        </span>
                        <h1 class="product-title">
                            <%= product.name %>
                        </h1>

                        <div class="product-meta">
                            <div class="product-seller-info">
                                <i class="fas fa-store"></i>
                                <strong>
                                    <%= product.seller_name %>
                                </strong>
                                <span class="verified-badge">
                                    <i class="fas fa-check-circle"></i> Verified Seller
                                </span>
                            </div>
                            <!-- Rating Header -->
                            <div class="product-rating-header" style="margin-top: 5px; color: var(--secondary);">
                                <% for(let i=1; i<=5; i++) { %>
                                    <i class="<%= i <= Math.round(avgRating) ? 'fas' : 'far' %> fa-star"></i>
                                    <% } %>
                                        <span style="color: var(--gray-600); margin-left: 5px;">
                                            (<%= reviewCount %> reviews)
                                        </span>
                            </div>
                        </div>

                        <div class="price-section">
                            <span class="current-price">Ksh <%= parseFloat(product.price).toFixed(2) %></span>
                            <% if (product.stock_quantity> 0) { %>
                                <span class="badge badge-success">In Stock</span>
                                <% } else { %>
                                    <span class="badge badge-warning">Out of Stock</span>
                                    <% } %>
                        </div>

                        <div class="product-description">
                            <h3>Product Description</h3>
                            <p>
                                <%= product.description %>
                            </p>

                            <ul class="product-features">
                                <% if (product.is_organic) { %>
                                    <li><i class="fas fa-check"></i> Certified Organic</li>
                                    <% } %>
                                        <% if (product.delivery_available) { %>
                                            <li><i class="fas fa-check"></i> Delivery Available</li>
                                            <% } %>
                                                <% if (product.warranty_included) { %>
                                                    <li><i class="fas fa-check"></i> Warranty Included</li>
                                                    <% } %>
                                                        <li><i class="fas fa-check"></i> Condition: <%=
                                                                product.condition_type.charAt(0).toUpperCase() +
                                                                product.condition_type.slice(1) %>
                                                        </li>
                            </ul>
                        </div>

                        <div class="product-specs">
                            <h3>Specifications</h3>
                            <div class="specs-grid">
                                <div class="spec-item">
                                    <span class="spec-label">Unit:</span>
                                    <span class="spec-value">
                                        <%= product.unit %>
                                    </span>
                                </div>
                                <div class="spec-item">
                                    <span class="spec-label">Category:</span>
                                    <span class="spec-value">
                                        <%= product.category.charAt(0).toUpperCase() + product.category.slice(1) %>
                                    </span>
                                </div>
                                <div class="spec-item">
                                    <span class="spec-label">Stock:</span>
                                    <span
                                        class="spec-value <%= product.stock_quantity > 0 ? 'text-success' : 'text-error' %>">
                                        <%= product.stock_quantity %>
                                            <%= product.unit %> available
                                    </span>
                                </div>
                                <div class="spec-item">
                                    <span class="spec-label">Location:</span>
                                    <span class="spec-value">
                                        <%= product.location %>
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="product-actions">
                            <div class="quantity-selector">
                                <label>Quantity:</label>
                                <div class="quantity-controls">
                                    <button class="qty-btn" onclick="decrementQty()">-</button>
                                    <input type="number" value="1" min="1" max="<%= product.stock_quantity %>"
                                        class="qty-input" id="quantity">
                                    <button class="qty-btn" onclick="incrementQty()">+</button>
                                </div>
                            </div>

                            <% if (product.stock_quantity> 0) { %>
                                <form action="/chat/start" method="POST" style="display:inline;">
                                    <input type="hidden" name="productId" value="<%= product.id %>">
                                    <input type="hidden" name="sellerId" value="<%= product.seller_id %>">
                                    <button type="submit" class="btn btn-primary btn-lg">
                                        <i class="fas fa-comment-dots"></i> Message Seller
                                    </button>
                                </form>
                                <% } else { %>
                                    <button class="btn btn-primary btn-lg" disabled>
                                        <i class="fas fa-times"></i> Out of Stock
                                    </button>
                                    <% } %>
                                        <a href="mailto:<%= product.seller_email %>" class="btn btn-secondary btn-lg">
                                            <i class="fas fa-envelope"></i> Email Seller
                                        </a>
                        </div>
                    </div>
                    <!-- Reviews Section -->
                    <div class="reviews-section"
                        style="margin-top: 40px; background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
                        <h3 style="font-size: 1.5rem; margin-bottom: 20px; color: var(--gray-900);">Customer Reviews
                        </h3>

                        <!-- Write Review Form -->
                        <% if (locals.user) { %>
                            <div class="write-review"
                                style="margin-bottom: 30px; padding-bottom: 30px; border-bottom: 1px solid var(--gray-200);">
                                <h4 style="margin-bottom: 15px;">Write a Review</h4>
                                <form action="/market/<%= product.id %>/review" method="POST">
                                    <div style="margin-bottom: 15px;">
                                        <label style="display: block; margin-bottom: 5px;">Rating:</label>
                                        <select name="rating" required
                                            style="padding: 8px; border-radius: 6px; border: 1px solid var(--gray-300);">
                                            <option value="5">5 - Excellent</option>
                                            <option value="4">4 - Very Good</option>
                                            <option value="3">3 - Good</option>
                                            <option value="2">2 - Fair</option>
                                            <option value="1">1 - Poor</option>
                                        </select>
                                    </div>
                                    <div style="margin-bottom: 15px;">
                                        <label style="display: block; margin-bottom: 5px;">Comment:</label>
                                        <textarea name="comment" rows="3" required
                                            style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid var(--gray-300);"></textarea>
                                    </div>
                                    <button type="submit" class="btn btn-primary">Submit Review</button>
                                </form>
                            </div>
                            <% } else { %>
                                <p style="margin-bottom: 30px;"><a href="/auth/login"
                                        style="color: var(--primary); text-decoration: underline;">Log in</a> to write a
                                    review.</p>
                                <% } %>

                                    <!-- Reviews List -->
                                    <div class="reviews-list">
                                        <% if (reviews.length===0) { %>
                                            <p style="color: var(--gray-500); font-style: italic;">No reviews yet. Be
                                                the first to review!</p>
                                            <% } else { %>
                                                <% reviews.forEach(function(review) { %>
                                                    <div class="review-item" style="margin-bottom: 20px;">
                                                        <div class="review-header"
                                                            style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                                                            <strong>
                                                                <%= review.user_name %>
                                                            </strong>
                                                            <div class="stars" style="color: var(--secondary);">
                                                                <% for(let i=1; i<=5; i++) { %>
                                                                    <i class="<%= i <= review.rating ? 'fas' : 'far' %> fa-star"
                                                                        style="font-size: 0.8rem;"></i>
                                                                    <% } %>
                                                            </div>
                                                        </div>
                                                        <p style="color: var(--gray-700); line-height: 1.5;">
                                                            <%= review.comment %>
                                                        </p>
                                                        <small style="color: var(--gray-400);">
                                                            <%= new Date(review.created_at).toLocaleDateString() %>
                                                        </small>
                                                    </div>
                                                    <% }); %>
                                                        <% } %>
                                    </div>
                    </div>
                </div>
        </main>

        <%- include('../partials/footer') %>

            <script src="/js/main.js"></script>
            <script>
                function incrementQty() {
                    const input = document.getElementById('quantity');
                    const max = parseInt(input.max);
                    if (parseInt(input.value) < max) {
                        input.value = parseInt(input.value) + 1;
                    }
                }

                function decrementQty() {
                    const input = document.getElementById('quantity');
                    if (parseInt(input.value) > 1) {
                        input.value = parseInt(input.value) - 1;
                    }
                }
            </script>
</body>

</html>