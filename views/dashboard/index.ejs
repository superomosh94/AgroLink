<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body>
    <%- include('../partials/header') %>

        <main>
            <div class="dashboard-container">
                <%- include('../partials/sidebar', { page: 'overview' }) %>

                    <div class="dashboard-content">
                        <div class="dashboard-header">
                            <h1>Dashboard Overview</h1>
                            <a href="/market/add/new" class="btn btn-primary">
                                <i class="fas fa-plus"></i> Add New Product
                            </a>
                        </div>

                        <!-- Stats Cards -->
                        <div class="stats-grid">
                            <div class="stat-card">
                                <div class="stat-icon stat-icon-primary">
                                    <i class="fas fa-box"></i>
                                </div>
                                <div class="stat-details">
                                    <span class="stat-label">Total Products</span>
                                    <span class="stat-value">
                                        <%= stats.totalProducts %>
                                    </span>
                                    <span class="stat-change">
                                        <i class="fas fa-info-circle"></i> Listed products
                                    </span>
                                </div>
                            </div>

                            <div class="stat-card">
                                <div class="stat-icon stat-icon-success">
                                    <i class="fas fa-dollar-sign"></i>
                                </div>
                                <div class="stat-details">
                                    <span class="stat-label">Total Sales</span>
                                    <span class="stat-value">Ksh <%= parseFloat(stats.totalSales).toFixed(2) %></span>
                                    <span class="stat-change">
                                        <i class="fas fa-shopping-cart"></i>
                                        <%= stats.orderCount %> orders
                                    </span>
                                </div>
                            </div>

                            <div class="stat-card">
                                <div class="stat-icon stat-icon-warning">
                                    <i class="fas fa-clock"></i>
                                </div>
                                <div class="stat-details">
                                    <span class="stat-label">Pending Orders</span>
                                    <span class="stat-value">
                                        <%= stats.pendingOrders %>
                                    </span>
                                    <span class="stat-change">
                                        <i class="fas fa-hourglass-half"></i> Awaiting action
                                    </span>
                                </div>
                            </div>

                            <div class="stat-card">
                                <div class="stat-icon stat-icon-info">
                                    <i class="fas fa-chart-line"></i>
                                </div>
                                <div class="stat-details">
                                    <span class="stat-label">Growth</span>
                                    <span class="stat-value">
                                        <%= products.length %>
                                    </span>
                                    <span class="stat-change positive">
                                        <i class="fas fa-arrow-up"></i> Active listings
                                    </span>
                                </div>
                            </div>
                        </div>

                        <!-- My Products -->
                        <div class="dashboard-section">
                            <h2 class="section-title">My Products</h2>
                            <% if (products.length===0) { %>
                                <div class="empty-state">
                                    <i class="fas fa-box-open"></i>
                                    <h3>No Products Yet</h3>
                                    <p>Start selling by adding your first product</p>
                                    <a href="/market/add/new" class="btn btn-primary">
                                        <i class="fas fa-plus"></i> Add Product
                                    </a>
                                </div>
                                <% } else { %>
                                    <div class="products-table">
                                        <table>
                                            <thead>
                                                <tr>
                                                    <th>Product</th>
                                                    <th>Category</th>
                                                    <th>Price</th>
                                                    <th>Stock</th>
                                                    <th>Status</th>
                                                    <th>Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% products.forEach(product=> { %>
                                                    <tr>
                                                        <td>
                                                            <strong>
                                                                <%= product.name %>
                                                            </strong>
                                                        </td>
                                                        <td>
                                                            <%= product.category.charAt(0).toUpperCase() +
                                                                product.category.slice(1) %>
                                                        </td>
                                                        <td>Ksh <%= parseFloat(product.price).toFixed(2) %>
                                                        </td>
                                                        <td>
                                                            <%= product.stock_quantity %>
                                                                <%= product.unit %>
                                                        </td>
                                                        <td>
                                                            <span
                                                                class="badge badge-<%= product.status === 'active' ? 'success' : 'warning' %>">
                                                                <%= product.status.charAt(0).toUpperCase() +
                                                                    product.status.slice(1) %>
                                                            </span>
                                                        </td>
                                                        <td>
                                                            <a href="/market/<%= product.id %>"
                                                                class="btn btn-sm btn-outline" title="View">
                                                                <i class="fas fa-eye"></i>
                                                            </a>
                                                            <a href="/market/<%= product.id %>/edit"
                                                                class="btn btn-sm btn-outline" title="Edit">
                                                                <i class="fas fa-edit"></i>
                                                            </a>
                                                        </td>
                                                    </tr>
                                                    <% }); %>
                                            </tbody>
                                        </table>
                                    </div>
                                    <% } %>
                        </div>

                        <!-- Recent Activity -->
                        <% if (recentOrders.length> 0) { %>
                            <div class="dashboard-section">
                                <h2 class="section-title">Recent Orders</h2>
                                <div class="activity-list">
                                    <% recentOrders.forEach(order=> { %>
                                        <div class="activity-item">
                                            <div class="activity-icon activity-icon-success">
                                                <i class="fas fa-shopping-cart"></i>
                                            </div>
                                            <div class="activity-content">
                                                <p class="activity-text">
                                                    <strong>Order #<%= order.id %></strong>
                                                    <% if (order.product_name) { %> - <%= order.product_name %>
                                                            <% } %>
                                                </p>
                                                <span class="activity-time">
                                                    <%= new Date(order.created_at).toLocaleDateString() %>
                                                </span>
                                            </div>
                                            <span class="activity-amount text-success">Ksh <%=
                                                    parseFloat(order.total_amount).toFixed(2) %></span>
                                        </div>
                                        <% }); %>
                                </div>
                            </div>
                            <% } %>
                    </div>
            </div>

            <!-- Mobile Sidebar Toggle -->
            <button class="mobile-sidebar-toggle" id="sidebarToggle" aria-label="Toggle Sidebar">
                <i class="fas fa-bars"></i>
            </button>
            <div class="sidebar-overlay" id="sidebarOverlay"></div>
        </main>

        <script src="/js/main.js"></script>
</body>

</html>