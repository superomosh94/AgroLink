<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body>
    <%- include('../partials/header') %>

        <main>
            <div class="dashboard-container">
                <%- include('../partials/sidebar', { page: 'messages' }) %>

                    <div class="dashboard-content">
                        <div class="dashboard-header">
                            <h1>Messages</h1>
                        </div>

                        <div class="dashboard-section">
                            <% if (chats.length===0) { %>
                                <div class="empty-state">
                                    <i class="fas fa-comments"></i>
                                    <h3>No Messages Yet</h3>
                                    <p>Contact sellers from the marketplace to start a conversation.</p>
                                    <a href="/market" class="btn btn-primary">Browse Marketplace</a>
                                </div>
                                <% } else { %>
                                    <div class="inbox-list">
                                        <% chats.forEach(chat=> { %>
                                            <a href="/dashboard/messages/<%= chat.id %>" class="message-card">
                                                <div class="message-avatar">
                                                    <i class="fas fa-user-circle"></i>
                                                </div>
                                                <div class="message-info">
                                                    <div class="message-header">
                                                        <h4>
                                                            <%= chat.other_user_name %>
                                                        </h4>
                                                        <span class="message-time">
                                                            <%= chat.last_message_time ? new
                                                                Date(chat.last_message_time).toLocaleDateString()
                                                                : 'New' %>
                                                        </span>
                                                    </div>
                                                    <p class="message-product">
                                                        <i class="fas fa-tag"></i>
                                                        <%= chat.product_name %>
                                                    </p>
                                                    <p class="message-preview">
                                                        <%= chat.last_message ? (chat.last_message.substring(0, 50)
                                                            + '...' ) : 'Start the conversation...' %>
                                                    </p>
                                                </div>
                                            </a>
                                            <% }); %>
                                    </div>
                                    <% } %>
                        </div>
                    </div>
            </div>

            <!-- Mobile Sidebar Toggle -->
            <button class="mobile-sidebar-toggle" id="sidebarToggle"><i class="fas fa-bars"></i></button>
            <div class="sidebar-overlay" id="sidebarOverlay"></div>
        </main>

        <script src="/js/main.js"></script>
        <style>
            .inbox-list {
                display: flex;
                flex-direction: column;
                gap: var(--spacing-md);
            }

            .message-card {
                display: flex;
                gap: var(--spacing-lg);
                padding: var(--spacing-lg);
                background: var(--gray-50);
                border-radius: var(--radius-lg);
                text-decoration: none;
                color: inherit;
                transition: all 0.2s;
                border: 1px solid transparent;
            }

            .message-card:hover {
                background: var(--white);
                border-color: var(--primary);
                box-shadow: var(--shadow-md);
                transform: translateX(5px);
            }

            .message-avatar {
                font-size: 40px;
                color: var(--gray-400);
                display: flex;
                align-items: center;
            }

            .message-info {
                flex: 1;
            }

            .message-header {
                display: flex;
                justify-content: space-between;
                margin-bottom: var(--spacing-xs);
            }

            .message-product {
                font-size: 0.85rem;
                color: var(--secondary);
                font-weight: 600;
                margin-bottom: var(--spacing-xs);
            }

            .message-preview {
                color: var(--gray-600);
                font-size: 0.9rem;
            }
        </style>
</body>

</html>