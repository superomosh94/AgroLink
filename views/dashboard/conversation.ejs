<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="/socket.io/socket.io.js"></script>
</head>

<body>
    <%- include('../partials/header') %>

        <main>
            <div class="dashboard-container">
                <%- include('../partials/sidebar', { page: 'messages' }) %>

                    <div class="dashboard-content chat-layout">
                        <div class="chat-main">
                            <!-- Chat Header -->
                            <div class="chat-header">
                                <div class="chat-user">
                                    <a href="/dashboard/messages" class="back-btn"><i class="fas fa-arrow-left"></i></a>
                                    <i class="fas fa-user-circle user-avatar-sm"></i>
                                    <div>
                                        <h3>
                                            <%= chat.other_user_name %>
                                        </h3>
                                        <div class="product-context">
                                            <i class="fas fa-box"></i>
                                            <%= chat.product_name %> (Ksh <%= chat.product_price %>)
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Messages Area -->
                            <div class="messages-container" id="messagesList">
                                <% messages.forEach(msg=> { %>
                                    <div class="message-bubble <%= msg.sender_id === user.id ? 'sent' : 'received' %>">
                                        <div class="message-content">
                                            <%= msg.message %>
                                        </div>
                                        <div class="message-time">
                                            <%= new Date(msg.created_at).toLocaleTimeString([], {hour: '2-digit' ,
                                                minute:'2-digit'}) %>
                                        </div>
                                    </div>
                                    <% }); %>
                            </div>

                            <!-- Input Area -->
                            <div class="chat-input-area">
                                <form id="chatForm">
                                    <input type="text" id="messageInput" placeholder="Type a message..."
                                        autocomplete="off" required>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fas fa-paper-plane"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
            </div>

            <button class="mobile-sidebar-toggle" id="sidebarToggle"><i class="fas fa-bars"></i></button>
            <div class="sidebar-overlay" id="sidebarOverlay"></div>
        </main>

        <script src="/js/main.js"></script>

        <script>
            const socket = io();
            const chatId = <%= chat.id %>;
            const currentUserId = <%= user.id %>;
            const otherUserId = <%= chat.other_user_id %>;
            const messagesList = document.getElementById('messagesList');
            const chatForm = document.getElementById('chatForm');
            const messageInput = document.getElementById('messageInput');

            // Scroll to bottom
            messagesList.scrollTop = messagesList.scrollHeight;

            // Join chat room
            socket.emit('join_chat', chatId);

            // Send Message
            chatForm.addEventListener('submit', (e) => {
                e.preventDefault();
                const message = messageInput.value.trim();

                if (message) {
                    socket.emit('send_message', {
                        chatId: chatId,
                        message: message,
                        receiverId: otherUserId
                    });
                    messageInput.value = '';
                }
            });

            // Receive Message
            socket.on('receive_message', (data) => {
                const isMyMessage = data.sender_id === currentUserId;
                appendMessage(data.message, data.created_at, isMyMessage);
                messagesList.scrollTop = messagesList.scrollHeight;
            });

            function appendMessage(text, time, isSent) {
                const div = document.createElement('div');
                div.className = `message-bubble ${isSent ? 'sent' : 'received'}`;

                const timeStr = new Date(time).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

                div.innerHTML = `
                <div class="message-content">${text}</div>
                <div class="message-time">${timeStr}</div>
            `;

                messagesList.appendChild(div);
            }
        </script>

        <style>
            .chat-layout {
                padding: 0;
                display: flex;
                flex-direction: column;
                height: calc(100vh - 80px);
            }

            .chat-main {
                display: flex;
                flex-direction: column;
                height: 100%;
                background: #fff;
            }

            .chat-header {
                padding: 1rem;
                border-bottom: 1px solid var(--gray-200);
                background: var(--gray-50);
            }

            .chat-user {
                display: flex;
                align-items: center;
                gap: 1rem;
            }

            .back-btn {
                color: var(--gray-600);
                font-size: 1.2rem;
                margin-right: 0.5rem;
            }

            .product-context {
                font-size: 0.85rem;
                color: var(--secondary);
                margin-top: 2px;
            }

            .messages-container {
                flex: 1;
                overflow-y: auto;
                padding: 1.5rem;
                display: flex;
                flex-direction: column;
                gap: 1rem;
                background: #f9fafb;
            }

            .message-bubble {
                max-width: 70%;
                padding: 10px 15px;
                border-radius: 15px;
                position: relative;
            }

            .message-bubble.sent {
                align-self: flex-end;
                background: var(--primary);
                color: white;
                border-bottom-right-radius: 2px;
            }

            .message-bubble.received {
                align-self: flex-start;
                background: var(--gray-200);
                color: var(--gray-800);
                border-bottom-left-radius: 2px;
            }

            .message-time {
                font-size: 0.7rem;
                margin-top: 5px;
                opacity: 0.8;
                text-align: right;
            }

            .chat-input-area {
                padding: 1rem;
                border-top: 1px solid var(--gray-200);
                background: white;
            }

            #chatForm {
                display: flex;
                gap: 10px;
            }

            #messageInput {
                flex: 1;
                padding: 12px;
                border: 1px solid var(--gray-300);
                border-radius: 25px;
                outline: none;
            }

            #messageInput:focus {
                border-color: var(--primary);
            }
        </style>
</body>

</html>