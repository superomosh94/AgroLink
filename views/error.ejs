<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body>
    <%- include('partials/header') %>

        <main style="min-height: 50vh; display: flex; align-items: center; justify-content: center;">
            <div class="container text-center">
                <i class="fas fa-times-circle"
                    style="font-size: 100px; color: var(--error); margin-bottom: var(--spacing-lg);"></i>
                <h1 style="font-size: var(--font-size-4xl); margin-bottom: var(--spacing-md);">Oops! Something Went
                    Wrong</h1>
                <p style="font-size: var(--font-size-lg); color: var(--gray-600); margin-bottom: var(--spacing-xl);">
                    <%= message || 'An unexpected error occurred. Please try again later.' %>
                </p>
                <a href="/" class="btn btn-primary btn-lg">
                    <i class="fas fa-home"></i> Back to Home
                </a>
            </div>
        </main>

        <%- include('partials/footer') %>

            <script src="/js/main.js"></script>
</body>

</html>