<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="AgroLink - Connecting Agricultural Stakeholders">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/home.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body>
    <%- include('partials/header') %>

        <main>
            <!-- Hero Section -->
            <section class="hero">
                <div class="container">
                    <div class="hero-content">
                        <div class="hero-text">
                            <h1 class="hero-title">
                                Connect. Trade. <span class="text-gradient">Grow.</span>
                            </h1>
                            <p class="hero-description">
                                AgroLink brings together farmers, suppliers, and buyers on one seamless platform.
                                Buy and sell agricultural products with confidence.
                            </p>
                            <div class="hero-buttons">
                                <a href="/auth/register" class="btn btn-primary btn-lg">
                                    Get Started <i class="fas fa-arrow-right"></i>
                                </a>
                                <a href="/market" class="btn btn-outline btn-lg">
                                    Explore Marketplace
                                </a>
                            </div>
                            <div class="hero-stats">
                                <div class="stat-item">
                                    <div class="stat-number">10K+</div>
                                    <div class="stat-label">Active Users</div>
                                </div>
                                <div class="stat-item">
                                    <div class="stat-number">50K+</div>
                                    <div class="stat-label">Products Listed</div>
                                </div>
                                <div class="stat-item">
                                    <div class="stat-number">98%</div>
                                    <div class="stat-label">Satisfaction</div>
                                </div>
                            </div>
                        </div>
                        <div class="hero-image">
                            <div class="image-wrapper">
                                <i class="fas fa-tractor hero-icon"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Detailed Value Proposition -->
            <section class="value-prop" style="padding: 100px 0; background: var(--white);">
                <div class="container">
                    <div class="section-header text-center">
                        <h2 class="section-title">A Marketplace for Everyone</h2>
                        <p class="section-description">Whether you are harvesting or buying, we have tools built just
                            for you.</p>
                    </div>

                    <div class="split-features"
                        style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;">
                        <!-- For Farmers -->
                        <div class="feature-detail-card"
                            style="padding: 2rem; background: var(--gray-50); border-radius: 1rem; border-left: 5px solid var(--primary);">
                            <div class="icon-header"
                                style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
                                <i class="fas fa-tractor" style="font-size: 2rem; color: var(--primary);"></i>
                                <h3 style="margin:0; font-size: 1.5rem;">For Farmers</h3>
                            </div>
                            <ul style="list-style: none; padding: 0;">
                                <li style="margin-bottom: 1rem; display: flex; gap: 10px;">
                                    <i class="fas fa-check-circle" style="color: var(--success); margin-top: 4px;"></i>
                                    <span><strong>Direct Market Access:</strong> Skip the middlemen and sell directly to
                                        consumers at fair prices.</span>
                                </li>
                                <li style="margin-bottom: 1rem; display: flex; gap: 10px;">
                                    <i class="fas fa-check-circle" style="color: var(--success); margin-top: 4px;"></i>
                                    <span><strong>Inventory Management:</strong> Track your stock, update prices, and
                                        manage orders easily.</span>
                                </li>
                                <li style="margin-bottom: 1rem; display: flex; gap: 10px;">
                                    <i class="fas fa-check-circle" style="color: var(--success); margin-top: 4px;"></i>
                                    <span><strong>Verified Seller Status:</strong> Earn trust with a verification badge
                                        and seller ratings.</span>
                                </li>
                            </ul>
                            <a href="/auth/register" class="btn btn-outline" style="margin-top: 1rem;">Start Selling</a>
                        </div>

                        <!-- For Buyers -->
                        <div class="feature-detail-card"
                            style="padding: 2rem; background: var(--gray-50); border-radius: 1rem; border-left: 5px solid var(--secondary);">
                            <div class="icon-header"
                                style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
                                <i class="fas fa-shopping-basket" style="font-size: 2rem; color: var(--secondary);"></i>
                                <h3 style="margin:0; font-size: 1.5rem;">For Buyers</h3>
                            </div>
                            <ul style="list-style: none; padding: 0;">
                                <li style="margin-bottom: 1rem; display: flex; gap: 10px;">
                                    <i class="fas fa-check-circle" style="color: var(--success); margin-top: 4px;"></i>
                                    <span><strong>Fresh Produce:</strong> Source high-quality products directly from
                                        local farms.</span>
                                </li>
                                <li style="margin-bottom: 1rem; display: flex; gap: 10px;">
                                    <i class="fas fa-check-circle" style="color: var(--success); margin-top: 4px;"></i>
                                    <span><strong>Transparent Pricing:</strong> Compare prices and negotiate directly
                                        via secure chat.</span>
                                </li>
                                <li style="margin-bottom: 1rem; display: flex; gap: 10px;">
                                    <i class="fas fa-check-circle" style="color: var(--success); margin-top: 4px;"></i>
                                    <span><strong>Secure Transactions:</strong> Only pay when you are satisfied with the
                                        product quality.</span>
                                </li>
                            </ul>
                            <a href="/market" class="btn btn-primary" style="margin-top: 1rem;">Start Browsing</a>
                        </div>
                    </div>
                </div>
            </section>

            <!-- How It Works Section (Enhanced) -->
            <section class="how-it-works" style="background: var(--white);">
                <div class="container">
                    <div class="section-header text-center">
                        <h2 class="section-title">How It Works</h2>
                        <p class="section-description">Simple steps to get started with AgroLink</p>
                    </div>

                    <div class="steps-grid">
                        <div class="step-card">
                            <div class="step-number">01</div>
                            <h3>Create Account</h3>
                            <p>Register as a farmer, supplier, or buyer in seconds.</p>
                        </div>
                        <div class="step-line"></div>
                        <div class="step-card">
                            <div class="step-number">02</div>
                            <h3>List or Browse</h3>
                            <p>Sellers post products; Buyers search for deals.</p>
                        </div>
                        <div class="step-line"></div>
                        <div class="step-card">
                            <div class="step-number">03</div>
                            <h3>Connect & Trade</h3>
                            <p>Chat directly and complete secure transactions.</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- CTA Section -->
            <section class="cta">
                <div class="container">
                    <div class="cta-content">
                        <h2 class="cta-title">Ready to Transform Your Agricultural Business?</h2>
                        <p class="cta-text">
                            Join thousands of farmers and suppliers already thriving on AgroLink
                        </p>
                        <a href="/auth/register" class="btn btn-secondary btn-lg">
                            Start Selling Today <i class="fas fa-rocket"></i>
                        </a>
                    </div>
                </div>
            </section>
        </main>

        <%- include('partials/footer') %>

            <script src="/js/main.js"></script>
</body>

</html>